			```
		formatString: Short Date
		lineageTag: 174a62da-8618-4f54-807a-47f11df3f533
		summarizeBy: none

		variation Variation
			isDefault
			relationship: ef1fd862-443f-49bf-8be7-c5d12a101797
			defaultHierarchy: LocalDateTable_f05d12b6-5388-44eb-b017-6c2ccf2deb4a.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	partition Calender = calculated
		mode: import
		source = ```
				
				GENERATE (
				  CALENDAR ( DATE ( 2024, 1, 1 ),  TODAY()),
				  VAR currentDay = [Date]
				  VAR day = DAY( currentDay )
				  VAR week = WEEKNUM( currentDay,1)
				  VAR month =  MONTH ( currentDay )
				  VAR year =  YEAR ( currentDay )
				  VAR yearMonth = FORMAT(currentDay, "YYYY/MM")
				  VAR quarter = QUARTER(currentDay)
				  VAR yearQuarter = YEAR ( currentDay ) & "/Q"& QUARTER(currentDay)
				    VAR yearweek = FORMAT ( [Date], "YYYY" ) & "/Week" & WEEKNUM([Date])
				  VAR yearNow = IF(year = YEAR(TODAY()),1,0)
				  VAR years = FORMAT(IF(yearNow = 1, "Current year", YEAR(currentDay)), "")
				  VAR upcoming = FORMAT(IF(currentDay > TODAY(),1,0),"")
				RETURN   ROW (
				  "day", day,
				  "week", week,
				  "month", month,
				  "year", year,
				  "yearMonth", yearMonth, 
				  "quarter", quarter,
				  "yearQuarter", yearQuarter,
				  "yearweek",yearweek,
				  "yearNow", yearNow,
				  "years", years,
				  "upcoming", upcoming)
				)
				```

	annotation PBI_Id = 59c7e411846341acaef294d2d181202d

