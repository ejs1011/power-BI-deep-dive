	measure 'DistinctTaskGroupCount (Orders)' = ```
			
			
			VAR JoinedTable = CALCULATE( DISTINCTCOUNT('InventoryTasks (2)'[TaskGroupPrimaryKey]),
			    FILTER(
			        CROSSJOIN( InventoryTasks_CycleCount, 'InventoryTasks (2)'),
			        InventoryTasks_CycleCount[InventoryTaskPrimaryKey] = 'InventoryTasks (2)'[PrimaryKey] &&
			        'InventoryTasks (2)'[IsClosed] = FALSE() &&
			        DATEVALUE( InventoryTasks_CycleCount[LastUpdatedDate] ) = DATEVALUE( 'InventoryTasks (2)'[LastUpdatedDate] )
			    ))
			RETURN
			     JoinedTable  +0
			
			
			
			
