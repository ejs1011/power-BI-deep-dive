		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Units Stocked per Bin(s)' = ```
			
			
			VAR UnitsPerBin =
			    SUMMARIZE(
			        Inventory,
			        Inventory[ContainerPrimaryKey],
			        "TotalUnitsInBin", 
			            IF(
			                ISBLANK(SUM(Inventory[Quantity])),
			                0,
			                SUM(Inventory[Quantity])
			            )
			    )
			RETURN
			    IF(
			        ISBLANK(AVERAGEX(UnitsPerBin, [TotalUnitsInBin])),
			        0,
			        ROUND(AVERAGEX(UnitsPerBin, [TotalUnitsInBin]), 2)
			    )
			
			
			```
		lineageTag: 8afda641-3a02-4016-b429-2b4b1062e5b5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Units Stocked per SKU' = ```
			
			
			VAR TotalUnitsPerProduct =
			    SUMMARIZE(
			        Products,
			        Products[PrimaryKey],
			        "TotalQuantity",
			            COALESCE(
			                SUMX(
			                    FILTER(
			                        Inventory,
			                        Inventory[UnitOfMeasurePrimaryKey] IN
			                            SELECTCOLUMNS(
			                                FILTER(
			                                    UnitsOfMeasure,
			                                    UnitsOfMeasure[ProductPrimaryKey] = Products[PrimaryKey]
			                                ),
			                                "UnitOfMeasurePrimaryKey", UnitsOfMeasure[PrimaryKey]
			                            )
			                    ),
			                    Inventory[Quantity]
			                ),
			                0 -- Replace blanks with 0
			            )
			    )
			RETURN
			    COALESCE(
			        AVERAGEX(TotalUnitsPerProduct, [TotalQuantity]),
			        0 -- Replace blank average with 0
			    )
			
			
			```
		lineageTag: d1181464-a09d-4e22-8be7-179e860405e5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Locations Stocked per SKU' = ```
			
			VAR TotalCompartmentsSum =
			    COALESCE(
			        CALCULATE(
			            COUNTROWS(Inventory),
			            TREATAS(
			                VALUES(UnitsOfMeasure[PrimaryKey]),
			                Inventory[UnitOfMeasurePrimaryKey]
			            ),
			            CROSSFILTER(UnitsOfMeasure[ProductPrimaryKey], Products[PrimaryKey], BOTH)
			        ),
			        0
			    )
			
			VAR ProductCount = COALESCE(COUNTROWS(Products), 0)
			
			RETURN 
			    DIVIDE(TotalCompartmentsSum, ProductCount, 0)
			
			
