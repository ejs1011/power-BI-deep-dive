	measure '% of Total Bin(s)' = ```
			
			
			DIVIDE(
			    COALESCE([Total Bin(s) w/ Inventory], 0) + COALESCE([Total Bin(s) w/ No Inventory], 0),
			    COALESCE([Total Bin(s)], 1),
			    0
			)
			
			
