	measure 'Units Stocked' = ```
			
			VAR UniqueInventory =
			    SUMMARIZE(
			        FILTER(
			            'Inventory',
			            'Inventory'[Status] <> "Pending"
			        ),
			        'Inventory'[PrimaryKey],
			        'Inventory'[Quantity]
			    )
			VAR FilteredContainers =
			    FILTER(
			        'Containers',
			        'Containers'[Status] <> "Outside"
			    )
			VAR Result =
			    SUMX(
			        UniqueInventory,
			        'Inventory'[Quantity]
			    )
			RETURN
			    COALESCE(Result, 0)
			 
			// COALESCE(
			//     CALCULATE(
