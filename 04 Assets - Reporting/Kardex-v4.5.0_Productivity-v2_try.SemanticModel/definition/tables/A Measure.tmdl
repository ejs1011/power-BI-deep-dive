	measure 'Total Bin(s) w/ Inventory' = ```
			
			
			COALESCE(
			    CALCULATE(
			        DISTINCTCOUNT(Inventory[ContainerPrimaryKey]),
			        Inventory[Status] <> "Pending",
			        Inventory[Quantity] > 0,
			        TREATAS(
			            -- Build a single‐column table of valid container keys from Containers
			            SELECTCOLUMNS(
			                FILTER(Containers, Containers[Status] <> "Outside"),
			                "ContKey", Containers[PrimaryKey]
			            ),
			            Inventory[ContainerPrimaryKey]
			        )
			    ),
			    0
			)
			
			
			
			
