	measure 'Total Locations Empty' = ```
			
			VAR ContainerFiltered =
			    FILTER(
			        'Containers',
			        'Containers'[Status] <> "Outside"
			    )
			VAR CompartmentWithContainers =
			    CROSSJOIN(
			        ContainerFiltered,
			        'ContainerTemplateCompartments'
			    )
			VAR InventoryByCompartment =
			    ADDCOLUMNS(
			        CompartmentWithContainers,
			        "IsGoodsToPerson",
			            LOOKUPVALUE(
			                'ContainerTemplates'[IsGoodsToPerson],
			                'ContainerTemplates'[PrimaryKey],
			                'Containers'[TemplatePrimaryKey]
			            ),
			        "HasInventory",
			            VAR currentContainer = 'Containers'[PrimaryKey]
			            VAR currentX = 'ContainerTemplateCompartments'[XPosition]
			            VAR currentY = 'ContainerTemplateCompartments'[YPosition]
			            VAR InventoryCount =
			                CALCULATE(
			                    COUNTROWS('Inventory'),
			                    FILTER(
			                        'Inventory',
			                        'Inventory'[ContainerPrimaryKey] = currentContainer &&
			                        'Inventory'[ContainerX] = currentX &&
			                        'Inventory'[ContainerY] = currentY &&
			                        'Inventory'[Status] <> "Pending"
			                    )
			                )
			            RETURN IF(InventoryCount > 0, 1, 0)
			    )
			VAR FilteredCompartments =
			    FILTER(
			        InventoryByCompartment,
			        [IsGoodsToPerson] = TRUE()
			    )
			VAR TotalCompartments =
			    COUNTROWS(FilteredCompartments)
			VAR OccupiedCompartments =
			    SUMX(FilteredCompartments, [HasInventory])
			RETURN
			    TotalCompartments - OccupiedCompartments
			
			
			
			// VAR Total = [Total Locations]
			// VAR Occupied = [Total Locations Occupied 2]
			// RETURN 
			//     COALESCE(Total - Occupied, 0)
			
			
			
			```
		formatString: 0
		lineageTag: e993566c-6528-450b-ac44-cea1cc578818

