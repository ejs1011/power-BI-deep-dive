	measure KPI_Selected_OWH = ```
			
			VAR SelectedMetric = SELECTEDVALUE( 'MetricsSlicer OWH'[Metric] )
			VAR SelectedSeries = SELECTEDVALUE( KPI_Series[Series] )
			RETURN
			SWITCH(
			    SelectedMetric,
			    "Orders",
			        SWITCH(
			            SelectedSeries,
			            "Orders Pick", [FulfillmentOrdersCount (Orders)],
			            "Orders Put", [PutAwayContainersOpenCount (Orders)],
			            "Orders Cycle Count", [DistinctTaskGroupCount (Orders)],
			            BLANK()  // For series not matching Orders
			        ),
			    "Lines",
			        SWITCH(
			            SelectedSeries,
			            "Lines Pick", [FulfillmentOrderLinesCount (Lines)],
			            "Lines Put", [PutAwayLineItemsCount (Lines)],
			            "Lines Cycle Count", [CycleCountOpenTasks (Lines)],
			            BLANK()
			        ),
			    // "Bins",
