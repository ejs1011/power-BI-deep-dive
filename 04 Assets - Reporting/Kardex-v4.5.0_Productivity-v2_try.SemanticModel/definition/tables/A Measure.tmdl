	measure 'Avg Units Stocked Per Location' = ```
			
			
			
			// VAR UniqueCompartments =
			//     SUMMARIZE(
			//         ContainerTemplateCompartments,
			//         ContainerTemplateCompartments[XPosition],
			//         ContainerTemplateCompartments[YPosition],
			//         ContainerTemplateCompartments[TemplatePrimaryKey],
			//         ContainerTemplateCompartments[CompartmentSizePrimaryKey] -- Ensuring correct mapping
			//     )
			
			// VAR UniqueInventory =
			//     SUMMARIZE(
			//         Inventory,
			//         Inventory[ContainerPrimaryKey],
			//         Inventory[ContainerX],
			//         Inventory[ContainerY],
			//         "UnitsStocked", MAX(Inventory[Quantity]) -- Ensuring only the latest snapshot quantity
			//     )
			
			// VAR TotalUnitsStocked =
			//     CALCULATE(
			//         SUMX(UniqueInventory, [UnitsStocked]), -- Summing only distinct quantities per compartment
			//         FILTER(Containers, Containers[Status] <> "Outside"),
			//         FILTER(ContainerTemplates, ContainerTemplates[IsGoodsToPerson] = TRUE())
			//     )
			
			// VAR CompartmentCube =
			//     SUMX(
			//         UniqueCompartments,
			//         VAR CompartmentSize = 
			//             CALCULATE(
			//                 MAX(CompartmentSizes[TotalHorizontalUnits]),
			//                 FILTER(CompartmentSizes, CompartmentSizes[PrimaryKey] = ContainerTemplateCompartments[CompartmentSizePrimaryKey])
			//             )
			//         VAR ContainerLength = 
			//             CALCULATE(
			//                 MAX(ContainerTemplates[Length]),
			//                 FILTER(ContainerTemplates, ContainerTemplates[PrimaryKey] = ContainerTemplateCompartments[TemplatePrimaryKey])
			//             )
			//         VAR ContainerWidth = 
			//             CALCULATE(
			//                 MAX(ContainerTemplates[Width]),
			//                 FILTER(ContainerTemplates, ContainerTemplates[PrimaryKey] = ContainerTemplateCompartments[TemplatePrimaryKey])
			//             )
			//         VAR ContainerHeight = 
			//             CALCULATE(
			//                 MAX(ContainerTemplates[Height]),
			//                 FILTER(ContainerTemplates, ContainerTemplates[PrimaryKey] = ContainerTemplateCompartments[TemplatePrimaryKey])
			//             )
			//         RETURN
			//             ContainerLength * ContainerWidth * ContainerHeight * (CompartmentSize / 8.0) * (CompartmentSize / 4.0)
			//     )
			
			// VAR TotalCompartmentCube =
			//     SUMX(UniqueCompartments, CompartmentCube) -- Summing the calculated compartment cubes
			
			// RETURN
			//     DIVIDE(TotalUnitsStocked, TotalCompartmentCube, BLANK())  -- Using BLANK() to avoid division by zero
			
			
			
			
			
			
			
			
			VAR Compartments =
			    -- Generate a table with the distinct combinations of relevant keys.
			    CROSSJOIN(
			        VALUES(Containers[PrimaryKey]),
			        VALUES(ContainerTemplateCompartments[XPosition]),
			        VALUES(ContainerTemplateCompartments[YPosition])
			    )
			    
			VAR TotalUnitsStocked =
			    -- Calculate the total inventory quantity, replacing blanks with 0.
			    COALESCE(
			        CALCULATE(
			            SUM(Inventory[Quantity]),
			            TREATAS(VALUES(Containers[PrimaryKey]), Inventory[ContainerPrimaryKey]),
			            TREATAS(VALUES(ContainerTemplateCompartments[XPosition]), Inventory[ContainerX]),
			            TREATAS(VALUES(ContainerTemplateCompartments[YPosition]), Inventory[ContainerY])
			        ),
			        0
			    )
			    
			VAR CompartmentCount =
			    -- Count the compartments and use COALESCE to ensure a blank count becomes 0.
			    COALESCE(COUNTROWS(Compartments), 0)
			    
			RETURN
			    -- Safely divide the total units by the count of compartments.
			    DIVIDE(TotalUnitsStocked, CompartmentCount, 0)
			
			
			
			
			
			
			
			
			
			
			
			```
