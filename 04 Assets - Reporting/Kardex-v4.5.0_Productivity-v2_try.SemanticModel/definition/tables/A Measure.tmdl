	measure '% of Bin(s) w/ No Inventory' = ```
			
			
			VAR BinsWithStock = COALESCE([Total Bin(s) w/ No Inventory], 0)
			VAR Total = COALESCE([Total Bin(s)], 0)
			RETURN 
			    IF(
			        Total = 0,
			        "0%",
			        CONCATENATE(
			            ROUND((BinsWithStock / Total) * 100, 2) & "%",
			            ""
			        )
			    )
			
			
			
			```
