	measure 'Pick OWH' =
			
			VAR SelMetric = [SelectedMetricValue]
			RETURN
			SWITCH(
			    TRUE(),
			    SelMetric = "Orders",
			        CALCULATE(
			            COUNTROWS(Pick),
			            /* Example filter: only include picks associated with orders */
			            NOT(ISBLANK(Pick[TransportOrderPrimaryKey]))
			        ),
			    SelMetric = "Lines",
			        CALCULATE(
			            COUNTROWS(Pick),
			            /* Example filter: only include picks associated with a line (replace with your logic) */
			            NOT(ISBLANK(Pick[PercentOfOrderLine]))
			        ),
			    SelMetric = "Bins",
			        CALCULATE(
			            COUNTROWS(Pick),
			            /* Example filter: only include picks associated with bins (replace with your logic) */
			            NOT(ISBLANK(Pick[PrimaryKey]))
			        ),
			    SelMetric = "All",
			        COUNTROWS(Pick),
			    BLANK()
			)
			
			// CALCULATE(
			//     COUNTROWS(Pick),
			//     FILTER(
			//         Pick,
			//         [SelectedMetricValue] > 0
			//     )
			// )
		formatString: 0
		lineageTag: 58bd63db-c8d0-43a9-9e28-897a46445b0b

