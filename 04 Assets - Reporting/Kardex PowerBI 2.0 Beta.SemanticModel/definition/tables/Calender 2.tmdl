		annotation SummarizationSetBy = Automatic

	partition 'Calender 2' = calculated
		mode: import
		source = ```
				
				GENERATE (
				  CALENDAR ( DATE ( 2024, 1, 1 ),  TODAY()),
				  VAR currentDay = [Date]
				  VAR day = DAY( currentDay )
				  VAR week = WEEKNUM( currentDay,1)
				  VAR month =  MONTH ( currentDay )
				  VAR year =  YEAR ( currentDay )
				  VAR yearMonth = FORMAT(currentDay, "YYYY/MM")
				  VAR quarter = QUARTER(currentDay)
				  VAR yearQuarter = YEAR ( currentDay ) & "/Q"& QUARTER(currentDay)
				    VAR yearweek = FORMAT ( [Date], "YYYY" ) & "/Week" & WEEKNUM([Date])
				  VAR yearNow = IF(year = YEAR(TODAY()),1,0)
				  VAR years = FORMAT(IF(yearNow = 1, "Current year", YEAR(currentDay)), "")
				  VAR upcoming = FORMAT(IF(currentDay > TODAY(),1,0),"")
				RETURN   ROW (
				  "day", day,
				  "week", week,
				  "month", month,
				  "year", year,
				  "yearMonth", yearMonth, 
				  "quarter", quarter,
				  "yearQuarter", yearQuarter,
				  "yearweek",yearweek,
				  "yearNow", yearNow,
				  "years", years,
				  "upcoming", upcoming)
				)
				```

	annotation PBI_Id = ef98be31554e457db7ed40523635a94f

