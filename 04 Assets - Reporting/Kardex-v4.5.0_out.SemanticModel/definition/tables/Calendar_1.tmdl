	column DateOnly = DATEVALUE('Calendar_1'[Date])
		formatString: Short Date
		lineageTag: ec37ca97-6a01-44b1-97d9-d4763941419b
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 73c650cc-9f35-4488-880f-987ef7e69482
			defaultHierarchy: LocalDateTable_e933ac72-c31d-47ca-a67c-3c7cd592ddbb.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	partition Calendar_1 = calculated
		mode: import
		source = ```
				
				GENERATE (
				  CALENDAR ( DATE ( 2024, 1, 1 ),  TODAY()),
				  VAR currentDay = [Date]
				  VAR day = DAY( currentDay )
				  VAR week = WEEKNUM( currentDay,1)
				  VAR month =  MONTH ( currentDay )
				  VAR year =  YEAR ( currentDay )
				  VAR yearMonth = FORMAT(currentDay, "YYYY/MM")
				  VAR quarter = QUARTER(currentDay)
				  VAR yearQuarter = YEAR ( currentDay ) & "/Q"& QUARTER(currentDay)
				    VAR yearweek = FORMAT ( [Date], "YYYY" ) & "/Week" & WEEKNUM([Date])
				  VAR yearNow = IF(year = YEAR(TODAY()),1,0)
				  VAR years = FORMAT(IF(yearNow = 1, "Current year", YEAR(currentDay)), "")
				  VAR upcoming = FORMAT(IF(currentDay > TODAY(),1,0),"")
				RETURN   ROW (
				  "day", day,
				  "week", week,
				  "month", month,
				  "year", year,
				  "yearMonth", yearMonth, 
				  "quarter", quarter,
				  "yearQuarter", yearQuarter,
				  "yearweek",yearweek,
				  "yearNow", yearNow,
				  "years", years,
				  "upcoming", upcoming)
				)
				```

	annotation PBI_Id = 4e5b719bb9614daaa228706cf9f413e8

