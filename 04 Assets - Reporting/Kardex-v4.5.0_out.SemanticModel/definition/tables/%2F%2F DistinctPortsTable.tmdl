				VAR Table1Ports = SELECTCOLUMNS(AverageHandlingTimePerPort, "Ports", AverageHandlingTimePerPort[Ports])
				VAR Table2Ports = SELECTCOLUMNS(BinPresentationsCompletedPerPort, "Ports", BinPresentationsCompletedPerPort[Ports])
				VAR Table3Ports = SELECTCOLUMNS(BinsPerHourPerPort, "Ports", BinsPerHourPerPort[Ports])
				VAR Table4Ports = SELECTCOLUMNS(LinesCompletedPerPort, "Ports", LinesCompletedPerPort[Ports])
				VAR Table5Ports = SELECTCOLUMNS(LinesperHourPerPort, "Ports", LinesperHourPerPort[Ports])
				VAR Table6Ports = SELECTCOLUMNS(MachineWaitTimePerPort, "Ports", MachineWaitTimePerPort[Ports])
				VAR Table7Ports = SELECTCOLUMNS(OrdersCompletedPerPort, "Ports", OrdersCompletedPerPort[Ports])
				VAR Table8Ports = SELECTCOLUMNS(OrdersPerHourPerPort, "Ports", OrdersPerHourPerPort[Ports])
				VAR Table9Ports = SELECTCOLUMNS(TotalLoggedTimePerPort, "Ports", TotalLoggedTimePerPort[Ports])
				VAR Table10Ports = SELECTCOLUMNS(UnitsCompletedPerPort, "Ports", UnitsCompletedPerPort[Ports])
				VAR Table11Ports = SELECTCOLUMNS(UnitsPerHourPerPort, "Ports", UnitsPerHourPerPort[Ports])
				
				VAR UnionAllPorts =
				    UNION(
				        Table1Ports,
				        Table2Ports,
				        Table3Ports,
				        Table4Ports,
				        Table5Ports,
				        Table6Ports,
				        Table7Ports,
				        Table8Ports,
				        Table9Ports,
				        Table10Ports,
				        Table11Ports
				    )
				VAR DistinctPorts = DISTINCT(UnionAllPorts)
				RETURN
				ADDCOLUMNS(
				    DistinctPorts,
				    "SortOrder",
				    VAR PortText = [Ports]
				    VAR PortNumberText = SUBSTITUTE(PortText, "P", "")
				    RETURN
				        IF(
				            ISBLANK(PortText) || PortText = "No Data" || PortText = "Unattributed",
				            999999,
				            IFERROR(VALUE(PortNumberText), 999999)
				        )
				)
				
				 
				
				
