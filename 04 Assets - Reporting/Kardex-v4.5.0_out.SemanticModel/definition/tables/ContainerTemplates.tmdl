	column CompartmentName = ```
			
			VAR CompartmentSizePrimaryKey =
			    LOOKUPVALUE(
			        'ContainerTemplateCompartments'[CompartmentSizePrimaryKey], 
			        'ContainerTemplateCompartments'[TemplatePrimaryKey], 
			        'ContainerTemplates'[PrimaryKey]
			    )
			VAR CompartmentName = 
			    LOOKUPVALUE(
			        'CompartmentSizes'[Name], 
			        'CompartmentSizes'[PrimaryKey], 
			        CompartmentSizePrimaryKey
			    )
			RETURN
			    IF(
			        'ContainerTemplates'[IsGoodsToPerson] = TRUE() && NOT ISBLANK(CompartmentName),
			        CompartmentName,
			        BLANK()
			    )
			
			```
		lineageTag: 231f1d5e-eb3f-4584-80b5-50613d95799e
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column CombinedName = ```
			
			VAR CompartmentPart = 'ContainerTemplates'[CompartmentName]
			VAR SpacePosition = SEARCH(" ", 'ContainerTemplates'[TemplateName], 1, LEN('ContainerTemplates'[TemplateName]))
			VAR TempletPart = IF(
			    SpacePosition <= LEN('ContainerTemplates'[TemplateName]),
			    MID('ContainerTemplates'[TemplateName], SpacePosition + 1, LEN('ContainerTemplates'[TemplateName])),
			    ""
			)
			VAR IsValidRow = 
			    CALCULATE(
			        COUNTROWS('ContainerTemplates'),
			        FILTER(
			
			            'ContainerTemplates',
			            // 'Containers'[Status] <> "Outside" &&
			            'ContainerTemplates'[IsGoodsToPerson] = TRUE()
			        )
			    ) > 0
			RETURN
			    IF(
			        IsValidRow,
			        CompartmentPart & " (" & TempletPart & ")",
			        BLANK()
			    )
			
			
			
			```
		lineageTag: 0c44d72b-4501-4a6b-b72f-6a221cd43fab
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

