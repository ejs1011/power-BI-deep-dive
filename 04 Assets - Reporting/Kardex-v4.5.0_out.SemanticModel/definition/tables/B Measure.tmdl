	lineageTag: 5f137cdb-18be-4ba3-bbf6-b9cb2d6ec2e4

	measure _DynamicMeasure = ```
			
			SWITCH(
			    TRUE(),
			    SELECTEDVALUE(_MeasureGroups[MeasureName]) = "Total Skus On Hand", [Total SKUs On Hand],
			    SELECTEDVALUE(_MeasureGroups[MeasureName]) = "Total Units On Hand", [Total Units On Hand],
			    SELECTEDVALUE(_MeasureGroups[MeasureName]) = "Total Locations Occupied", [Total Locations Occupied],
			    SELECTEDVALUE(_MeasureGroups[MeasureName]) = "Orders Putaway", [Orders Putaway],
			    SELECTEDVALUE(_MeasureGroups[MeasureName]) = "Units Putaway", [Units Putaway],
			    SELECTEDVALUE(_MeasureGroups[MeasureName]) = "Skus Putaway", [Skus Putaway],
			    SELECTEDVALUE(_MeasureGroups[MeasureName]) = "Presentations Putaway", [Presentations Putaway],
			    SELECTEDVALUE(_MeasureGroups[MeasureName]) = "Distinct bins inventory added", [Distinct bins inventory added],
			    SELECTEDVALUE(_MeasureGroups[MeasureName]) = "Distinct bin compartments that had inventory", [Distinct bin compartments that had inventory],
			    SELECTEDVALUE(_MeasureGroups[MeasureName]) = "Customer Orders Picked", [Customer Orders Picked],
			    SELECTEDVALUE(_MeasureGroups[MeasureName]) = "Customer Order Lines", [Customer Order Lines],
			    SELECTEDVALUE(_MeasureGroups[MeasureName]) = "Units Picked", [Units Picked],
			    SELECTEDVALUE(_MeasureGroups[MeasureName]) = "Distinct Skus Picked", [Distinct SKUs Picked],
			    
			    BLANK()+0
			)
			 
			```
		formatString: 0
		displayFolder: Daily KPI Summary Report
		lineageTag: 0d06113e-8439-469f-8f5c-c15289038ab3

	measure _DistinctLocationsOccupied = ```
			
			
