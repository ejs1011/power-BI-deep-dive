	measure _DistinctTotalInducted = ```
			
			
			CALCULATE(
			    DISTINCTCOUNT('Inventory'[ContainerPrimaryKey]),
			    FILTER(
			        'Inventory',
			        'Inventory'[Status] <> "Pending"
			    ),
			    FILTER(
			        'Containers',
			        'Containers'[Status] <> "Outside"
			    )
			)
			
			// CALCULATE (
			//     DISTINCTCOUNT ( Report_Data[ContainerBarcode] ),
			//     FILTER ( Report_Data, Report_Data[DataDescription] = "BinPresented" )
			// )
			
			
